@using SV22T1020670.Shop
@using SV22T1020670.Shop.AppCodes
@model List<SV22T1020670.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
    decimal totalAmount = Model.Sum(m => m.TotalPrice);
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-7 mb-4">
            <h4 class="fw-bold mb-4 text-uppercase">Thông tin giao hàng</h4>

            <form action="~/Order/PlaceOrder" method="post" id="checkoutForm">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Họ và tên người nhận</label>
                        <input type="text" class="form-control" name="deliveryName" required placeholder="Ví dụ: Nguyễn Văn A">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text" class="form-control" name="deliveryPhone" required placeholder="09xxxxxxx">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Email (Tùy chọn)</label>
                        <input type="email" class="form-control" name="deliveryEmail" placeholder="email@example.com">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tỉnh / Thành phố</label>
                        <select class="form-select" name="deliveryProvince" required>
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            <option value="Thừa Thiên Huế">Thừa Thiên Huế</option>
                            <option value="Hà Nội">Hà Nội</option>
                            <option value="TP Hồ Chí Minh">TP Hồ Chí Minh</option>
                            <option value="Đà Nẵng">Đà Nẵng</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Quận / Huyện</label>
                        <input type="text" class="form-control" name="deliveryDistrict" required placeholder="Nhập quận/huyện">
                    </div>

                    <div class="col-12">
                        <label class="form-label">Địa chỉ chi tiết</label>
                        <input type="text" class="form-control" name="deliveryAddress" required placeholder="Số nhà, tên đường...">
                    </div>
                </div>

                <hr class="my-4">

                <h4 class="fw-bold mb-3">Phương thức thanh toán</h4>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="cod" value="COD" checked>
                    <label class="form-check-label" for="cod">
                        Thanh toán khi nhận hàng (COD)
                    </label>
                </div>
                <div class="form-check mb-4">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="bank" value="BANK">
                    <label class="form-check-label" for="bank">
                        Chuyển khoản ngân hàng
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold text-uppercase">
                    Xác nhận đặt hàng
                </button>
            </form>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 bg-light rounded-3 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Đơn hàng của bạn</h5>

                    <div style="max-height: 400px; overflow-y: auto;" class="mb-3 p-3">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="position-relative me-3">
                                        <img src="@WebConfig.GetImageUrl("products", item.Photo)"
                                             class="rounded border" style="width: 50px; height: 50px; object-fit: cover;">

                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary"
                                              style="font-size: 0.6rem; border: 2px solid white;">
                                            @item.Quantity
                                        </span>
                                    </div>
                                    <div class="ms-3">
                                        <p class="mb-0 small fw-bold text-truncate" style="max-width: 150px;">@item.ProductName</p>
                                    </div>
                                </div>
                                <span class="small fw-bold">@item.TotalPrice.ToString("N0")đ</span>
                            </div>
                        }
                    </div>

                    <hr>
                    <div class="d-flex justify-content-between mb-2 mt-3">
                        <span>Tạm tính</span>
                        <span class="fw-bold">@totalAmount.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Phí vận chuyển</span>
                        <span class="text-success">Miễn phí</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="h5 fw-bold text-dark">Tổng cộng</span>
                        <span class="h4 fw-bold text-danger">@totalAmount.ToString("N0")đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>