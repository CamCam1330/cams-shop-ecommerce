@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4 p-md-5">

                    @if (ViewBag.Message != null)
                    {
                        // Hiển thị thông báo thành công
                        <div class="text-center">
                            <i class="fas fa-check-circle text-success" style="font-size: 60px;"></i>
                            <h4 class="fw-bold mt-3 text-success">Thành công!</h4>
                            <p class="text-muted my-4">@ViewBag.Message</p>
                            <a href="~/Account/Login" class="btn btn-primary rounded-pill px-4">Quay lại đăng nhập</a>
                        </div>
                    }
                    else
                    {
                        // Hiển thị Form nhập email
                        <div class="text-center mb-4">
                            <h3 class="fw-bold text-uppercase">Quên mật khẩu?</h3>
                            <p class="text-muted small">Nhập email của bạn để chúng tôi hỗ trợ lấy lại mật khẩu.</p>
                        </div>

                        <form action="~/Account/ForgotPassword" method="post">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger small rounded-3">
                                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                                </div>
                            }

                            <div class="form-floating mb-4">
                                <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required>
                                <label for="email">Nhập địa chỉ Email</label>
                            </div>

                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-primary btn-lg fw-bold text-uppercase rounded-pill">
                                    Gửi yêu cầu
                                </button>
                            </div>

                            <div class="text-center">
                                <a href="~/Account/Login" class="text-decoration-none text-muted small">
                                    <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
                                </a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>