@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = Context.Request.Query["ReturnUrl"];
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Cam's Shop</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            background-color: #f0f2f5;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 40px 30px;
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }

        .brand-title {
            color: #ed7117;
            font-weight: 800;
            letter-spacing: -1px;
        }

        .form-floating:focus-within {
            z-index: 2;
        }

        .form-control:focus {
            border-color: #ed7117;
            box-shadow: 0 0 0 0.25rem rgba(237, 113, 23, 0.25);
        }

        .btn-primary {
            background-color: #ed7117;
            border-color: #ed7117;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-primary:hover {
                background-color: #d65f0a;
                border-color: #d65f0a;
                transform: translateY(-1px);
            }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <h2 class="brand-title">Cam's <span class="text-dark">Shop</span></h2>
            <p class="text-muted small">Đăng nhập để nhận ưu đãi thành viên</p>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form action="~/Account/Login" method="post">
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show small" role="alert">
                    <i class="fas fa-exclamation-circle me-1"></i>
                    @Html.ValidationSummary(false, "", new { @class = "d-inline" })
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="form-floating mb-3">
                <input type="text" class="form-control" id="username" name="username" placeholder="name@example.com" required autofocus value="@ViewBag.UserName">
                <label for="username"><i class="fas fa-envelope me-2 text-muted"></i>Email / Tài khoản</label>
            </div>

            <div class="form-floating mb-3">
                <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
                <label for="password"><i class="fas fa-lock me-2 text-muted"></i>Mật khẩu</label>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label small text-muted" for="rememberMe">
                        Ghi nhớ đăng nhập
                    </label>
                </div>
                <a href="~/Account/ForgotPassword" class="small text-decoration-none text-muted">Quên mật khẩu?</a>
            </div>

            <div class="d-grid mb-4">
                <button type="submit" class="btn btn-primary btn-lg py-2 rounded-pill shadow-sm">
                    Đăng nhập ngay
                </button>
            </div>

            <div class="text-center mt-4">
                <p class="small text-muted mb-0">Bạn chưa có tài khoản?</p>
                <a href="~/Account/Register" class="fw-bold text-primary text-decoration-none" style="color: #ed7117;">Đăng ký ngay</a>

                <div class="mt-3">
                    <a href="/" class="small text-muted text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i> Quay về trang chủ
                    </a>
                </div>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>
</html>