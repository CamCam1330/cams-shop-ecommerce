@using SV22T1020670.Shop.AppCodes
@using SV22T1020670.Shop
@model SV22T1020670.Shop.Models.ProductSearchOutput
@{
    ViewData["Title"] = "Danh sách sản phẩm";
    var categories = ViewBag.Categories as List<SV22T1020670.DomainModels.Category>;
}

<div class="bg-light py-5 mb-4 text-center">
    <div class="container">
        <h1 class="fw-bold">Tất cả sản phẩm</h1>
        <p class="text-muted">Khám phá các sản phẩm chăm sóc sắc đẹp chính hãng</p>
    </div>
</div>

<div class="container pb-5">
    <form action="~/Product" method="get" id="searchForm">
        <input type="hidden" name="searchValue" value="@Model.SearchValue" />

        <div class="row">
            <div class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Bộ lọc</h5>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Danh mục</label>
                            <div class="d-flex flex-column gap-2">
                                <label class="d-flex align-items-center">
                                    <input type="radio" name="categoryID" value="0" class="me-2" data-auto-submit
                                           @(Model.CategoryID == 0 ? "checked" : "")>
                                    <span>Tất cả</span>
                                </label>
                                @if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        <label class="d-flex align-items-center">
                                            <input type="radio" name="categoryID" value="@cat.CategoryID" class="me-2" data-auto-submit
                                                   @(Model.CategoryID == cat.CategoryID ? "checked" : "")>
                                            <span>@cat.CategoryName</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Khoảng giá</label>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm" name="minPrice" placeholder="Từ" value="@(Model.MinPrice > 0 ? Model.MinPrice : "")">
                                </div>
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm" name="maxPrice" placeholder="Đến" value="@(Model.MaxPrice > 0 ? Model.MaxPrice : "")">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm w-100">Áp dụng</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm border">
                    <span class="text-muted">Tìm thấy <b class="text-primary">@Model.RowCount</b> sản phẩm</span>

                    <div class="d-flex align-items-center">
                        <label class="me-2 small text-muted text-nowrap"><i class="fas fa-sort me-1"></i>Sắp xếp:</label>
                        <select name="sortBy" class="form-select form-select-sm border-0 bg-light fw-bold" style="width: 160px; cursor: pointer;" data-auto-submit>
                            <!option value="" @(string.IsNullOrEmpty(Model.SortBy) ? "selected" : "")>Mặc định</!option>
                            <!option value="price_asc" @(Model.SortBy == "price_asc" ? "selected" : "")>Giá thấp đến cao</!option>
                            <!option value="price_desc" @(Model.SortBy == "price_desc" ? "selected" : "")>Giá cao đến thấp</!option>
                        </select>
                    </div>
                </div>

                @if (Model.Data.Any())
                {
                    <div class="row row-cols-2 row-cols-md-3 g-4">
                        @foreach (var item in Model.Data)
                        {
                            <div class="col">
                                <div class="product-card h-100 d-flex flex-column border rounded overflow-hidden shadow-hover bg-white">
                                    <div class="product-img-wrap position-relative bg-white border-bottom" style="padding-top: 100%;">
                                        <a href="~/Product/Details/@item.ProductID">
                                            <img src="@WebConfig.GetImageUrl("products", item.Photo)"
                                                 alt="@item.ProductName"
                                                 style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; padding: 15px;">
                                        </a>
                                        @if (item.SalePrice > 0 && item.SalePrice < item.Price)
                                        {
                                            var percent = (int)((1 - (item.SalePrice / item.Price)) * 100);
                                            <span class="position-absolute top-0 start-0 m-2 badge bg-danger">-@percent%</span>
                                        }
                                    </div>

                                    <div class="p-3 d-flex flex-column flex-grow-1">
                                        <div class="mb-2 text-muted small">@item.Unit</div>
                                        <a href="~/Product/Details/@item.ProductID" class="text-dark text-decoration-none fw-bold mb-auto" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @item.ProductName
                                        </a>

                                        <div class="mt-3 d-flex align-items-end justify-content-between">
                                            <div>
                                                @if (item.SalePrice > 0 && item.SalePrice < item.Price)
                                                {
                                                    <div class="text-primary fw-bold">@item.SalePrice.ToString("N0")đ</div>
                                                    <div class="text-muted small text-decoration-line-through">@item.Price.ToString("N0")đ</div>
                                                }
                                                else
                                                {
                                                    <div class="text-primary fw-bold">@item.Price.ToString("N0")đ</div>
                                                }
                                            </div>
                                            <button type="button" class="btn btn-outline-primary btn-sm rounded-circle" data-action="add-to-cart" data-product-id="@item.ProductID">
                                                <i class="fas fa-cart-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.PageCount > 1)
                    {
                        <div class="mt-5">
                            <nav>
                                <ul class="pagination justify-content-center">
                                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                        <button class="page-link" type="submit" name="page" value="@(Model.Page - 1)">
                                            <i class="fas fa-chevron-left"></i>
                                        </button>
                                    </li>

                                    @for (int p = 1; p <= Model.PageCount; p++)
                                    {
                                        <li class="page-item @(Model.Page == p ? "active" : "")">
                                            <button class="page-link" type="submit" name="page" value="@p">@p</button>
                                        </li>
                                    }

                                    <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                                        <button class="page-link" type="submit" name="page" value="@(Model.Page + 1)">
                                            <i class="fas fa-chevron-right"></i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-search fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Không tìm thấy sản phẩm nào phù hợp.</p>
                        <a href="~/Product" class="btn btn-outline-primary">Xem tất cả sản phẩm</a>
                    </div>
                }
            </div>
        </div>
    </form>
</div>
