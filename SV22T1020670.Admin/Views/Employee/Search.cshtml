@model PaginationSearchResult<SV22T1020670.DomainModels.Employee>

<!-- Hiển thị thông tin số lượng -->

<p style="margin:10px 0 10px 0">
    Có <strong>@Model.RowCount</strong> nhân viên trong tổng số <strong>@Model.PageCount</strong> trang.
</p>

<!-- Hiển thị dạng LƯỚI (Grid) -->

<div class="row">
    @if (Model.Data != null && Model.Data.Any())
    {
        foreach (var item in Model.Data)
        {
            <div class="col-sm-4">
                <div class="box box-info">
                    <div class="box-header with-border">
                        <h3 class="box-title">@item.FullName</h3>
                        <div class="box-tools pull-right">
                            <a class="btn btn-box-tool" href="~/Employee/Edit/@item.EmployeeID">
                                <i class="fa fa-edit text-primary"></i>
                            </a>
                            <a class="btn btn-box-tool" href="~/Employee/Delete/@item.EmployeeID">
                                <i class="fa fa-trash text-danger"></i>
                            </a>
                        </div>
                    </div>
                    <div class="box-body">
                        <div class="row">
                            <div class="col-sm-4">
                                <!-- Hiển thị ảnh nhân viên, nếu lỗi thì hiện ảnh mặc định -->
                                <img class="profile-user-img img-responsive img-bordered"
                                     src="~/images/employees/@item.Photo"
                                     onerror="this.src='/images/employees/nophoto.png'"
                                     alt="User Image">
                            </div>
                            <div class="col-sm-8">
                                <ul class="list-group list-group-unbordered">
                                    <li class="list-group-item" style="border-bottom: none; padding-bottom: 5px;">
                                        <i class="fa fa-birthday-cake"></i>
                                        @string.Format("{0:dd/MM/yyyy}", item.BirthDate)
                                    </li>
                                    <li class="list-group-item" style="border-bottom: none; padding-bottom: 5px;">
                                        <i class="fa fa-phone"></i> @item.Phone
                                    </li>
                                    <li class="list-group-item" style="border-bottom: none; padding-bottom: 5px;">
                                        <i class="fa fa-envelope"></i>
                                        <span style="font-size: 12px;">@item.Email</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-sm-12 text-center text-muted">
            <p>Không tìm thấy nhân viên nào.</p>
        </div>
    }
</div>

<!-- Pagination AJAX -->
@if (Model.PageCount > 1)
{
    <div class="text-center">
        <ul class="pagination">
            @for (int p = 1; p <= Model.PageCount; p++)
            {
                <li class="@(p == Model.Page ? "active" : "")">
                    <a href="javascript:searchData(@p);">@p</a>
                </li>
            }
        </ul>
    </div>
}