@model SV22T1020670.DomainModels.Employee
@{
    ViewBag.Title = "Xóa nhân viên";
}

<div class="box box-danger">
    <div class="box-body">
        <form class="form-horizontal" method="post" action="~/Employee/Delete/@Model.EmployeeID">

            <div class="form-group">
                <label class="control-label col-sm-2">Họ và tên:</label>
                <div class="col-sm-10">
                    <p class="form-control-static">@Model.FullName</p>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-sm-2">Ngày sinh:</label>
                <div class="col-sm-10">
                    <p class="form-control-static">@string.Format("{0:dd/MM/yyyy}", Model.BirthDate)</p>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-sm-2">Địa chỉ:</label>
                <div class="col-sm-10">
                    <p class="form-control-static">@Model.Address</p>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-sm-2">Điện thoại:</label>
                <div class="col-sm-10">
                    <p class="form-control-static">@Model.Phone</p>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-sm-2">Email:</label>
                <div class="col-sm-10">
                    <p class="form-control-static">@Model.Email</p>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-sm-2">Trạng thái:</label>
                <div class="col-sm-10">
                    <p class="form-control-static">@(Model.IsWorking ? "Đang làm việc" : "Đã nghỉ việc")</p>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-sm-2">Ảnh cá nhân:</label>
                <div class="col-sm-10">
                    @{
                        // Xử lý hiển thị ảnh: Nếu không có ảnh thì hiện ảnh mặc định
                        string photoPath = string.IsNullOrEmpty(Model.Photo)
                        ? "~/images/employees/nophoto.png"
                        : $"~/images/employees/{Model.Photo}";
                    }
                    <img src="@Url.Content(photoPath)" class="img img-bordered" style="width:150px" />
                </div>
            </div>

            <div class="form-group text-right">
                @{
                    // Kiểm tra Employee 
                    bool inUse = await SV22T1020670.BusinessLayers.CommonDataService.EmployeeDB.InUsedAsync(Model.EmployeeID);
                }

                @if (!inUse)
                {
                    <button type="submit" class="btn btn-danger">
                        <i class="fa fa-trash"></i> Xóa dữ liệu
                    </button>
                }
                else
                {
                    <div class="alert alert-warning text-center">
                        <strong>⚠️ Không được phép xóa!</strong><br />
                        Nhân viên này đang có dữ liệu liên quan (ví dụ: phụ trách đơn hàng).
                    </div>
                }

                <a href="~/Employee" class="btn btn-default">
                    <i class="fa fa-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>