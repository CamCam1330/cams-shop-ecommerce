@model SV22T1020670.DomainModels.PaginationSearchResult<SV22T1020670.DomainModels.Product>
@{
    Layout = null;
}

<p style="margin-top:10px">
    Hiển thị <strong>@Model.Data.Count()</strong> mặt hàng trên tổng số
    <strong>@Model.RowCount</strong> mặt hàng.
    (Trang <strong>@Model.Page</strong> / <strong>@Model.PageCount</strong>)
</p>

<div class="table-responsive">
    <table class="table table-bordered table-hover table-striped">
        <thead>
            <tr class="bg-primary text-white">
                <th style="width:80px">Ảnh</th>
                <th>Tên mặt hàng</th>
                <th>Đơn vị tính</th>
                <th>Tồn kho</th>
                <th>Giá</th>
                <th style="width:80px"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Data != null && Model.Data.Any())
            {
                foreach (var item in Model.Data)
                {
                    <tr>
                        <td>
                            <img class="img-responsive"
                                 src="~/images/products/@item.Photo"
                                 onerror="this.src='/images/products/nophoto.png'"
                                 style="width:auto; height:50px; max-width:60px"
                                 alt="@item.ProductName" />
                        </td>
                        <td>@item.ProductName</td>
                        <td>@item.Unit</td>

                        <td style="vertical-align:middle;">
                            @if (item.Quantity > 0)
                            {
                                <span>@string.Format("{0:N0}", item.Quantity)</span>
                            }
                            else
                            {
                                <span class="text-danger" style="font-weight:bold;">Hết hàng</span>
                            }
                        </td>

                        <td>@string.Format("{0:N0}", item.Price)</td>
                        <td class="text-right">
                            <a href="~/Product/Edit/@item.ProductID" class="btn btn-xs btn-info">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="~/Product/Delete/@item.ProductID" class="btn btn-xs btn-danger">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">Không có dữ liệu để hiển thị</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.PageCount > 1)
    {
        <div class="text-center">
            <ul class="pagination">
                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    <li class="@(i == Model.Page ? "active" : "")">
                        <a href="javascript:searchData(@i);">@i</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>