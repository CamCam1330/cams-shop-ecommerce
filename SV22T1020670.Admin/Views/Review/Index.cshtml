@model SV22T1020670.DomainModels.Models.PaginationSearchInput
@{
    ViewBag.Title = "Quản lý phản hồi";
}

<div class="box box-primary">
    <div class="box-body">
        <form id="formSearch" action="~/Review/Search" method="get" data-container="#searchResult">
            <div class="input-group">
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <input name="SearchValue" type="text" class="form-control"
                       placeholder="Nhập tên khách hàng hoặc tên sản phẩm cần tìm..."
                       value="@Model.SearchValue">

                <span class="input-group-btn">
                    <button type="submit" id="search-btn" class="btn btn-flat btn-info">
                        <i class="fa fa-search"></i> Tìm kiếm
                    </button>
                </span>
            </div>
        </form>

        <div id="searchResult"></div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Khi trang vừa load xong thì gọi hàm tìm kiếm ngay để hiện dữ liệu ban đầu
            $("#formSearch").submit();
        });

        // Xử lý sự kiện submit form (chặn load lại trang, dùng Ajax)
        $("#formSearch").submit(function (e) {
            e.preventDefault();
            doSearch(this, 1);
            return;
        });

        // Hàm xử lý tìm kiếm và phân trang chung
        function doSearch(formSearchInput, page) {
            var url = $(formSearchInput).prop("action");
            var container = $(formSearchInput).data("container");
            var postData = $(formSearchInput).serializeArray();
            postData.push({ "name": "page", "value": page });

            $.ajax({
                url: url,
                type: "POST",
                data: postData,
                error: function () {
                    alert("Your request is not valid!");
                },
                success: function (data) {
                    $(container).html(data);
                }
            });

            return;
        }
    </script>
}