@model SV22T1020670.DomainModels.Advertisement
@{
    ViewBag.Title = "Cập nhật Quảng cáo";
}

<div class="box box-primary">
    <div class="box-body">
        <form action="~/Advertisement/Save" method="post" enctype="multipart/form-data">
            <input type="hidden" name="@nameof(Model.BannerID)" value="@Model.BannerID" />
            <input type="hidden" name="@nameof(Model.Photo)" value="@Model.Photo" />

            <div class="form-group">
                <label>Tiêu đề:</label>
                <input type="text" class="form-control" name="@nameof(Model.Title)" value="@Model.Title" autofocus>
                @Html.ValidationMessage(nameof(Model.Title), new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label>Liên kết (Link):</label>
                <input type="text" class="form-control" name="@nameof(Model.Link)" value="@Model.Link" placeholder="Ví dụ: /Product/Search?query=abc">
            </div>

            <div class="form-group">
                <label>Thứ tự hiển thị:</label>
                <input type="number" class="form-control" name="@nameof(Model.DisplayOrder)" value="@Model.DisplayOrder">
            </div>

            <div class="form-group">
                <div class="checkbox">
                    <label>
                        <input type="checkbox" name="@nameof(Model.IsHidden)" value="true" @(Model.IsHidden ? "checked" : "")> Ẩn quảng cáo này
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label>Hình ảnh:</label>
                <input type="file" name="uploadPhoto" class="form-control" accept="image/*" onchange="document.getElementById('PhotoPreview').src = window.URL.createObjectURL(this.files[0])" />
                @Html.ValidationMessage(nameof(Model.Photo), new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <img id="PhotoPreview" src="~/images/banners/@Model.Photo" class="img-responsive" style="max-height: 200px; border: 1px solid #ddd;" />
            </div>

            <div class="form-group text-right">
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-floppy-o"></i> Lưu dữ liệu
                </button>
                <a href="~/Advertisement" class="btn btn-default">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>