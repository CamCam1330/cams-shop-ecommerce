@model PaginationSearchResult<SV22T1020670.DomainModels.Shipper>
@*
*@

<p style="margin:10px 0 10px 0">
    Hiển thị <strong>@Model.Data.Count()</strong> người giao hàng trên tổng số
    <strong>@Model.RowCount</strong> người giao hàng.
    (Trang <strong>@Model.Page</strong> / <strong>@Model.PageCount</strong>)
</p>

<div class="table-responsive">
    <table class="table table-bordered table-hover table-striped">
        <thead>
            <tr class="bg-primary text-white">
                <th>Tên người giao hàng</th>
                <th>Điện thoại</th>
                <th style="width:80px"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Data != null && Model.Data.Any())
            {
                foreach (var item in Model.Data)
                {
                    <tr>
                        <td>@item.ShipperName</td>
                        <td>@item.Phone</td>
                        <td class="text-right">
                            <a href="~/Shipper/Edit/@item.ShipperID" class="btn btn-xs btn-info" title="Sửa">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="~/Shipper/Delete/@item.ShipperID" class="btn btn-xs btn-danger" title="Xóa">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center text-muted">
                        Không có dữ liệu để hiển thị
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination (link gọi JavaScript) -->
@* Sửa lại điều kiện kiểm tra (lỗi logic ở file Code 7 của bạn) *@
@if (Model.PageCount > 1)
{
    <div class="text-center">
        <ul class="pagination">
            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="@(i == Model.Page ? "active" : "")">
                    <!-- Sửa href để gọi hàm searchData() -->
                    <a href="javascript:searchData(@i);">@i</a>
                </li>
            }
        </ul>
    </div>
}