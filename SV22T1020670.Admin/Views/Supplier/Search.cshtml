@model PaginationSearchResult<SV22T1020670.DomainModels.Supplier>

<p style="margin:10px 0 10px 0">
    Hiển thị <strong>@Model.Data.Count()</strong> nhà cung cấp trên tổng số
    <strong>@Model.RowCount</strong> nhà cung cấp.
    (Trang <strong>@Model.Page</strong> / <strong>@Model.PageCount</strong>)
</p>

<div class="table-responsive">
    <table class="table table-bordered table-hover table-striped">
        <thead>
            <tr class="bg-primary text-white">
                <th>Tên nhà cung cấp</th>
                <th>Tên giao dịch</th>
                <th>Điện thoại</th>
                <th>Email</th>
                <th>Địa chỉ</th>
                <th>Tỉnh/thành</th>
                <th style="width:80px"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Data != null && Model.Data.Any())
            {
                foreach (var item in Model.Data)
                {
                    <tr>
                        <td>@item.SupplierName</td>
                        <td>@item.ContactName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.Province</td>
                        <td class="text-right">
                            <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-xs btn-info" title="Sửa">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-xs btn-danger" title="Xóa">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        Không có dữ liệu để hiển thị
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination (sửa lại link để gọi hàm JavaScript) -->
@if (Model.PageCount > 1)
{
    <div class="text-center">
        <ul class="pagination">
            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="@(i == Model.Page ? "active" : "")">
                    <!-- Sửa href để gọi hàm searchData() -->
                    <a href="javascript:searchData(@i);">@i</a>
                </li>
            }
        </ul>
    </div>
}