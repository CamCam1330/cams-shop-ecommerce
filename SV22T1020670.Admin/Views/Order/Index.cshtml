@model SV22T1020670.DomainModels.PaginationSearchResult<SV22T1020670.DomainModels.Order>
@{
    ViewBag.Title = "Quản lý đơn hàng";
    // Lấy lại điều kiện tìm kiếm để hiển thị lại trên form
    var condition = ViewBag.Condition as SV22T1020670.DomainModels.OrderSearchInput;
}

<div class="box box-primary">
    <div class="box-body">
        <form id="formSearch" action="~/Order" method="get">
            <input type="hidden" name="Page" value="@Model.Page" />

            <div class="row container-fluid">
                <div class="col-sm-2">
                    <select class="form-control select2" name="Status" onchange="doSearch(1)">
                        @foreach (var status in condition.StatusList)
                        {
                            if (status.Value == condition.Status)
                            {
                                <option value="@status.Value" selected>@status.Text</option>
                            }
                            else
                            {
                                <option value="@status.Value">@status.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-sm-2">
                    <input type="text" name="DateRange" value="@condition?.DateRange" class="form-control daterange-picker" placeholder="" />
                </div>
                <div class="col-sm-8 input-group">
                    <input type="text" name="SearchValue" value="@Model.SearchValue"
                           class="form-control"
                           placeholder="Tìm kiếm theo tên khách hàng hoặc tên người giao hàng">
                    <span class="input-group-btn">
                        <button type="submit" id="search-btn" class="btn btn-flat btn-info">
                            <i class="fa fa-search"></i> Tìm kiếm
                        </button>
                    </span>
                </div>
            </div>
        </form>

        <div id="searchResult">
            <p style="margin:10px 0 10px 0">
                Có <strong>@string.Format("{0:N0}", Model.RowCount)</strong> đơn hàng trong tổng số <strong>@Model.PageCount</strong> trang
            </p>

            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped">
                    <thead>
                        <tr class="bg-primary">
                            <th>Khách hàng</th>
                            <th>Ngày lập</th>
                            <th>Nhân viên phụ trách</th>
                            <th>Thời điểm duyệt</th>
                            <th>Người giao hàng</th>
                            <th>Ngày nhận giao hàng</th>
                            <th>Thời điểm kết thúc</th>
                            <th>Trạng thái</th>
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Data)
                        {
                            <tr>
                                <td>@item.CustomerName</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.EmployeeName</td>
                                <td>@(item.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td>@item.ShipperName</td>
                                <td>@(item.ShippedTime?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td>@(item.FinishedTime?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td>@item.StatusDescription</td>
                                <td>
                                    <a href="~/Order/Details/@item.OrderID" class="btn btn-info btn-xs">
                                        <i class="glyphicon glyphicon-th-list"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-center">
                <ul class="pagination">
                    @for (int p = 1; p <= Model.PageCount; p++)
                    {
                        if (p == Model.Page)
                        {
                            <li class="active"><a href="#">@p</a></li>
                        }
                        else
                        {
                            <li><a href="javascript:;" onclick="doSearch(@p)">@p</a></li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function doSearch(page) {
            var searchCondition = $("#formSearch").serializeArray();
            searchCondition.push({ name: "Page", value: page });

            var action = $("#formSearch").prop("action");
            var method = $("#formSearch").prop("method");

            var container = "#searchResult";

            // Vì trang này load lại toàn bộ (không dùng Ajax Partial)
            // nên ta đổi Page trong input hidden rồi submit form
            $("input[name='Page']").val(page);
            $("#formSearch").submit();
        }

        $(document).ready(function () {
            $('.daterange-picker').daterangepicker({
                locale: {
                    format: 'DD/MM/YYYY'
                },
                autoUpdateInput: false
            });

            $('.daterange-picker').on('apply.daterangepicker', function(ev, picker) {
                $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + picker.endDate.format('DD/MM/YYYY'));
                // Tự động tìm kiếm khi chọn ngày xong (nếu muốn)
                // doSearch(1);
            });

            $('.daterange-picker').on('cancel.daterangepicker', function(ev, picker) {
                $(this).val('');
                // doSearch(1);
            });
        });
    </script>
}